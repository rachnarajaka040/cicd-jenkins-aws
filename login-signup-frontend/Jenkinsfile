node {
    def appDir = '/var/www/reactjs-app'
    
    stage('Clean Workspace') {
        deleteDir()
    }

    stage('Clone Repo') {
        echo 'Cloning repository...'
        git branch: 'main', url: 'https://github.com/rachnarajaka040/cicd-jenkins-aws.git'
    }

    stage('Deploy to EC2') {
        echo 'Deploying to EC2...'
        sh """
            # Create directory and set permissions
            sudo mkdir -p ${appDir}
            sudo chown -R jenkins:jenkins ${appDir}

            # Sync files (Corrected path from . / to ./)
            rsync -av --delete --exclude='.git' --exclude='node_modules' ./ ${appDir}/
            
            cd ${appDir}

            # Install and Build
            npm install
            npm run build --if-present

            # Kill existing process on port 3000 to allow restart
            sudo fuser -k 3000/tcp || true

            # Start the app in the background so Jenkins can finish
            BUILD_ID=dontKillMe nohup npm start > /dev/null 2>&1 &
        """
    }
}